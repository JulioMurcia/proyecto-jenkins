pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/JulioMurcia/proyecto-jenkins'
            }
        }

        stage('Install dependencies') {
            steps {
                bat '''
                docker run --rm ^
                -v %cd%:/app ^
                -w /app ^
                python:3.11 ^
                pip install -r requirements.txt
                '''
            }
        }

        stage('Run Tests') {
            steps {
                bat '''
                docker run --rm ^
                -v %cd%:/app ^
                -w /app ^
                python:3.11 ^
                pytest
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t devops-app .'
            }
        }

        stage('Run Container') {
            steps {
                bat '''
                docker stop devops-app
                docker rm devops-app
                docker run -d -p 5000:5000 --name devops-app devops-app
                '''
            }
        }
    }
}