pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/JulioMurcia/proyecto-jenkins'
            }
        }

        stage('Install dependencies') {
            steps {
                sh '''
                docker run --rm \
                -v $PWD:/app \
                -w /app \
                python:3.11 \
                pip install -r requirements.txt
                '''
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                docker run --rm \
                -v $PWD:/app \
                -w /app \
                python:3.11 \
                pytest
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t devops-app .'
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker stop devops-app || true
                docker rm devops-app || true
                docker run -d -p 5000:5000 --name devops-app devops-app
                '''
            }
        }
    }
}